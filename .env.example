# Furgonetka — skopiuj do .env.local (dev) lub .env (produkcja na VPS).
# NIE commitować pliku z prawdziwymi wartościami — sekrety zostają poza repo.

# BEZPIECZEŃSTWO — WYMAGANE w produkcji. Bez nich panel admina jest zablokowany.
# SESSION_SECRET: długi losowy ciąg do podpisu cookie sesji. Wygeneruj np.:
#   openssl rand -base64 48
SESSION_SECRET=
# Dane logowania do panelu /admin. Ustaw własne, mocne hasło.
ADMIN_LOGIN=admin
ADMIN_HASLO=

# Dane aplikacji OAuth z panelu Furgonetki (REST API: wycena, nadania, etykiety).
FURGONETKA_CLIENT_ID=
FURGONETKA_CLIENT_SECRET=
FURGONETKA_USERNAME=kontakt@nawiabizuteria.pl
FURGONETKA_PASSWORD=

# Klucz mapy punktów odbioru przypięty do domeny (widget map.js).
# Opcjonalny — jeśli mapa działa bez klucza, zostaw puste.
NEXT_PUBLIC_FURGONETKA_MAP_KEY=

# ——— Automatyczne nadania przesyłek (Etap 3) ———
# Master-flaga: dopiero "true" włącza tworzenie przesyłek przy zamówieniu.
# NAJPIERW przetestuj na demo (FURGONETKA_API_BASE), bo nadanie jest płatne.
FURGONETKA_NADANIA=false
# Baza API — na czas testów ustaw środowisko demo Furgonetki; puste = produkcja.
# FURGONETKA_API_BASE=https://api.furgonetka.pl
# service_id usług z Twojego konta Furgonetki (liczby). Sprawdź w panelu/API konta.
FURGONETKA_SERVICE_PACZKOMAT=
FURGONETKA_SERVICE_KURIER=
# Dane nadawcy (sklep) — drukowane na etykiecie.
NADAWCA_NAZWA=NAWIA
NADAWCA_FIRMA=
NADAWCA_ULICA=
NADAWCA_KOD=
NADAWCA_MIASTO=
NADAWCA_EMAIL=kontakt@nawiabizuteria.pl
NADAWCA_TELEFON=511168962
# Domyślne wymiary paczki (cm) i waga (kg) — biżuteria, mała paczka.
PACZKA_SZER=20
PACZKA_WYS=10
PACZKA_GLEB=15
PACZKA_WAGA=0.5

# SMTP (maile transakcyjne noreply) — skrzynka home.pl.
SMTP_HOST=poczta.home.pl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@nawiabizuteria.pl
SMTP_PASS=
SMTP_FROM=NAWIA <noreply@nawiabizuteria.pl>
# SMTP_REPLY_TO=   # zostaw puste dla prawdziwego "noreply"

# Adres, na który przychodzą powiadomienia o nowych zamówieniach (właścicielka).
SKLEP_EMAIL=patrycja.reszka0@wp.pl
